# ═══════════════════════════════════════════════════
# OpenFishh Configuration
# ═══════════════════════════════════════════════════

# LLM API (any OpenAI-compatible API)
# Options: OpenRouter, OpenAI, Anthropic, local Ollama
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4.1-nano

# That's it. No database, no memory service, no other keys.
# OpenFishh uses DuckDuckGo for search (free, no key needed).
